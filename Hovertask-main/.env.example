# Hovertask Main Site Environment Variables
# Copy this file to .env and update the values

# API URL (Backend)
# For local development: http://localhost:8000
# For production: https://backend.hovertask.com
VITE_API_URL=https://backend.hovertask.com

# Dashboard URL (for redirects after login)
# For local development: http://localhost:5173
# For production: https://app.hovertask.com
VITE_DASHBOARD_URL=https://app.hovertask.com

# App Version (optional, for cache busting)
VITE_APP_VERSION=1.0.0
