#!/bin/bash

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Configuration
LARAVEL_PORT=8000
DASHBOARD_PORT=5173
MARKETING_PORT=5174
LARAVEL_DIR="/Users/user/Desktop/hovertask/laravel-MKpr"
DASHBOARD_DIR="/Users/user/Desktop/hovertask/hovertask-dashboard"
MARKETING_DIR="/Users/user/Desktop/hovertask/Hovertask-main"
LOG_DIR="$HOME/.hovertask/logs"

# Create log directory
mkdir -p "$LOG_DIR"

# Function to cleanup on exit
cleanup() {
    echo -e "\n${YELLOW}Stopping all services...${NC}"
    kill $LARAVEL_PID $DASHBOARD_PID $MARKETING_PID 2>/dev/null
    echo -e "${GREEN}✓ All services stopped${NC}"
    exit 0
}

trap cleanup SIGINT SIGTERM

echo -e "${BLUE}════════════════════════════════════════════${NC}"
echo -e "${BLUE}    🚀 HOVERTASK - UNIFIED DEV SERVER${NC}"
echo -e "${BLUE}════════════════════════════════════════════${NC}"
echo ""

# Check prerequisites
echo -e "${YELLOW}[CHECK]${NC} Verifying prerequisites..."
if ! command -v php &> /dev/null; then
    echo -e "${RED}✗ PHP not found${NC}"
    exit 1
fi
if ! command -v npm &> /dev/null; then
    echo -e "${RED}✗ npm not found${NC}"
    exit 1
fi
echo -e "${GREEN}✓ Prerequisites OK${NC}"
echo ""

# Start Laravel Backend
echo -e "${YELLOW}[1/3]${NC} Starting ${BLUE}Laravel Backend${NC}..."
cd "$LARAVEL_DIR"
php artisan serve --port=$LARAVEL_PORT > "$LOG_DIR/laravel.log" 2>&1 &
LARAVEL_PID=$!
sleep 2
if kill -0 $LARAVEL_PID 2>/dev/null; then
    echo -e "${GREEN}✓ Laravel running${NC} (PID: $LARAVEL_PID)"
else
    echo -e "${RED}✗ Laravel failed to start${NC}"
    cat "$LOG_DIR/laravel.log"
    exit 1
fi
echo ""

# Start React Dashboard
echo -e "${YELLOW}[2/3]${NC} Starting ${BLUE}React Dashboard${NC}..."
cd "$DASHBOARD_DIR"
npm run dev > "$LOG_DIR/dashboard.log" 2>&1 &
DASHBOARD_PID=$!
sleep 3
if kill -0 $DASHBOARD_PID 2>/dev/null; then
    echo -e "${GREEN}✓ Dashboard running${NC} (PID: $DASHBOARD_PID)"
else
    echo -e "${RED}✗ Dashboard failed to start${NC}"
    cat "$LOG_DIR/dashboard.log"
    exit 1
fi
echo ""

# Start React Marketing Site
echo -e "${YELLOW}[3/3]${NC} Starting ${BLUE}React Marketing Website${NC}..."
cd "$MARKETING_DIR"
npm run dev > "$LOG_DIR/marketing.log" 2>&1 &
MARKETING_PID=$!
sleep 3
if kill -0 $MARKETING_PID 2>/dev/null; then
    echo -e "${GREEN}✓ Marketing running${NC} (PID: $MARKETING_PID)"
else
    echo -e "${RED}✗ Marketing failed to start${NC}"
    cat "$LOG_DIR/marketing.log"
    exit 1
fi
echo ""

# Display summary
echo -e "${BLUE}════════════════════════════════════════════${NC}"
echo -e "${GREEN}✅ ALL SERVICES STARTED!${NC}"
echo -e "${BLUE}════════════════════════════════════════════${NC}"
echo ""

echo -e "${YELLOW}🌐 Access Points:${NC}"
echo -e "  Dashboard:   ${GREEN}http://localhost:$DASHBOARD_PORT${NC}"
echo -e "  Marketing:   ${GREEN}http://localhost:$MARKETING_PORT${NC}"
echo -e "  API:         ${GREEN}http://localhost:$LARAVEL_PORT${NC}"
echo ""

echo -e "${YELLOW}🔑 Login Credentials:${NC}"
echo -e "  Email:       ${GREEN}test@hovertask.com${NC}"
echo -e "  Password:    ${GREEN}password123${NC}"
echo ""

echo -e "${YELLOW}📊 Process Information:${NC}"
echo -e "  Laravel PID:   $LARAVEL_PID"
echo -e "  Dashboard PID: $DASHBOARD_PID"
echo -e "  Marketing PID: $MARKETING_PID"
echo ""

echo -e "${YELLOW}📋 Log Files:${NC}"
echo -e "  ${GREEN}tail -f $LOG_DIR/laravel.log${NC}"
echo -e "  ${GREEN}tail -f $LOG_DIR/dashboard.log${NC}"
echo -e "  ${GREEN}tail -f $LOG_DIR/marketing.log${NC}"
echo ""

echo -e "${YELLOW}⚙️  Management:${NC}"
echo -e "  • Press ${GREEN}Ctrl+C${NC} to stop all services"
echo -e "  • View logs in ${GREEN}~/.hovertask/logs/${NC}"
echo ""

echo -e "${BLUE}════════════════════════════════════════════${NC}"
echo -e "${GREEN}Ready! Opening Dashboard...${NC}"
echo -e "${BLUE}════════════════════════════════════════════${NC}"
echo ""

# Open browser if possible
if command -v open &> /dev/null; then
    sleep 2
    open "http://localhost:$DASHBOARD_PORT"
fi

# Keep script running
wait
